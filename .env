ORGCHART_DB_CONNECTION=Host=orgchart-db;Database=orgchartdb;Username=orgchartuser;Password=orgchartpass;Include Error Detail=true

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Kafka Consumer - ORGCHART Configuration
ORGCHART_KAFKA_RECONNECT_BACKOFF_MS=50
ORGCHART_KAFKA_RECONNECT_BACKOFF_MAX_MS=5000
ORGCHART_KAFKA_TOPICS=notifications.email.auth,notifications.email.backend
ORGCHART_KAFKA_GROUP_ID=email-consumers
ORGCHART_KAFKA_AUTO_OFFSET_RESET=Earliest
ORGCHART_KAFKA_ENABLE_AUTO_COMMIT=false
ORGCHART_KAFKA_AUTO_COMMIT_INTERVAL_MS=5000
ORGCHART_KAFKA_SESSION_TIMEOUT_MS=30000
ORGCHART_KAFKA_MAX_POLL_INTERVAL_MS=300000
ORGCHART_KAFKA_API_VERSION_REQUEST_TIMEOUT_MS=10000